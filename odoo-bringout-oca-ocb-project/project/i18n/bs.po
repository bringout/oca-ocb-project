"    Best regards,\n"
"    <t t-if=\"user.signature\">\n"
"        <br/>\n"
"        <div data-o-mail-quote=\"1\">--<br data-o-mail-quote=\"1\"/><t t-out=\"user.signature or ''\">Mitchell Admin</t></div>\n"
