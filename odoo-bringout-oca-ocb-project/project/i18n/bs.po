"                            </td>\n"
"                            <td>\n"
"                                <a t-attf-href=\"/rate/{{ access_token }}/1\" t-att-class=\"'pe-none' if object._rating_get_operator() else ''\">\n"
"                                    <img alt=\"Nezadovoljan\" src=\"/rating/static/src/img/rating_1.png\" title=\"Nezadovoljan\"/>\n"
